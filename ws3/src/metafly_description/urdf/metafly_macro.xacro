<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="metafly" params="prefix">

    <!-- Make everything larger and easier to see -->
    <xacro:property name="body_length" value="0.6" />
    <xacro:property name="body_radius" value="0.06" />
    <xacro:property name="wing_length" value="0.5" />
    <xacro:property name="wing_width" value="0.25" />
    <xacro:property name="wing_thickness" value="0.05" />

    <!-- Base/body -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="${radians(90)} 0 0" />
        <geometry>
          <cylinder length="${body_length}" radius="${body_radius}" />
        </geometry>
        <material name="light_grey"/>
      </visual>

      <visual>
        <origin xyz="0 ${body_length/2} 0" rpy="0 0 0" />
        <geometry>
          <sphere radius="0.09"/>
        </geometry>
        <material name="blue"/>
      </visual>
    </link>

    <!-- Left wing -->
    <link name="${prefix}wing1">
      <visual>
        <origin xyz="-0.35 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.7 0.2 0.05" />
        </geometry>
        <material name="red"/>
      </visual>
    </link>

    <!-- Right wing -->
    <link name="${prefix}wing2">
      <visual>
        <origin xyz="0.35 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.7 0.2 0.05" />
        </geometry>
        <material name="green"/>
      </visual>
    </link>

    <!-- Joints -->
    <joint name="${prefix}joint1" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}wing1" />
      <axis xyz="0 1 0" />
      <limit effort="1" lower="${radians(-90)}" upper="${radians(90)}" velocity="1" />
    </joint>

    <joint name="${prefix}joint2" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}wing2" />
      <axis xyz="0 1 0" />
      <limit effort="1" lower="${radians(-90)}" upper="${radians(90)}" velocity="1" />
    </joint>

  </xacro:macro>
</robot>
